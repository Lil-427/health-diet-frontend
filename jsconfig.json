{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "src/**/*.js",
    "src/**/*.d.ts",
    "src/**/*.vue",
    "*.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
